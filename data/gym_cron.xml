<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Acción Planificada (Cron) para revisar suscripciones vencidas -->
        <record id="cron_check_expired_subscriptions" model="ir.cron">
            <field name="name">Revisar Suscripciones Vencidas</field>
            <field name="model_id" ref="model_gym_subscription"/>
            <field name="state">code</field>
            <field name="code">model.check_expired_subscriptions()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
