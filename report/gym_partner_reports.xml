<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Reporte: Ficha de Inscripción del Socio -->
        <record id="action_report_gym_partner_inscription" model="ir.actions.report">
            <field name="name">Ficha de Inscripción</field>
            <field name="model">gym.partner</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">gym_management.report_gym_partner_inscription</field>
